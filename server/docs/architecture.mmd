%%{init: {'flowchart': {'nodeSpacing': 35, 'rankSpacing': 65, 'curve': 'basis'}, 'themeVariables': {'fontSize': '16px'}}}%%
flowchart TD
    SDK["Client apps<br/>(x-api-key)"]
    Dashboard["Next.js dashboard<br/>(JWT cookie)"]

    subgraph API["server-api (Express)"]
        direction LR
        Ingest["POST /ingest"]
        Auth["/auth"]
        Admin["/admin/clients"]
        Analytics["/analytics"]
        Alerting["/alerting"]
        Audit["/audit-logs"]
    end

    MQ[("RabbitMQ<br/>server_monitoring_queue")]
    DLQ[("Dead-letter<br/>queue")]

    subgraph WORKERS[" "]
        direction LR
        EventConsumer["consumer<br/>EventConsumer"]
        AlertEval["alerting-worker<br/>Evaluator + Dispatcher"]
    end

    Notify["Slack / Discord / Email / Webhook"]

    subgraph DATA["Data stores"]
        direction LR
        Mongo[("MongoDB<br/>hits, clients, users,<br/>api keys, alerts, audit")]
        PG[("PostgreSQL<br/>endpoint_metrics")]
        Redis[("Redis<br/>rate limit, cache,<br/>idempotency")]
    end

    SDK --> Ingest
    Dashboard --> Auth & Admin & Analytics & Alerting & Audit

    Ingest -->|publish| MQ
    Ingest -.->|rate limit| Redis
    MQ --> EventConsumer

    EventConsumer -->|raw hit| Mongo
    EventConsumer -->|upsert hourly bucket| PG
    EventConsumer -->|poison / max retries| DLQ
    EventConsumer -.->|dedupe| Redis

    AlertEval -->|reads metrics| PG
    AlertEval -->|reads / writes fire log| Mongo
    AlertEval --> Notify

    Auth --> Mongo
    Admin --> Mongo
    Analytics --> PG
    Analytics --> Mongo
    Audit --> Mongo

    classDef external fill:#eef2ff,stroke:#6366f1,stroke-width:1.5px,color:#1e1b4b
    classDef api fill:#ecfeff,stroke:#0891b2,stroke-width:1.5px,color:#083344
    classDef queue fill:#fff7ed,stroke:#ea580c,stroke-width:1.5px,color:#7c2d12
    classDef worker fill:#f0fdf4,stroke:#16a34a,stroke-width:1.5px,color:#14532d
    classDef store fill:#fef2f2,stroke:#dc2626,stroke-width:1.5px,color:#7f1d1d
    classDef notify fill:#fdf4ff,stroke:#a21caf,stroke-width:1.5px,color:#581c87

    class SDK,Dashboard external
    class Ingest,Auth,Admin,Analytics,Alerting,Audit api
    class MQ,DLQ queue
    class EventConsumer,AlertEval worker
    class Mongo,PG,Redis store
    class Notify notify
